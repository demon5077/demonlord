# ================================
# DemonLord Environment Variables
# ================================

# TMDB API Key — get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ScreenScape API Key — get yours at https://screenscapeapi.dev/dashboard/apis
# Used for KMMovies, AnimeSalt, NetMirror, AnimePahe, HDHub4u, and more
SCREENSCAPE_API_KEY=
SCREENSCAPE_API_URL=https://screenscapeapi.dev

# Consumet API URL — self-host or use a public instance
CONSUMET_API_URL=https://consumet_api_url

# Download API
DOWNLOAD_API_URL=https://v1.api.ani.rohi.dev/api/dramacool

# M3U8 Proxy — see https://github.com/JulzOhern/Gogoanime-and-Hianime-proxy
PROXY_M3U8="https://yourproxy.com/fetch?url="

# Auth (Better Auth) — generate at https://generate-secret.vercel.app/32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://demonlord.pp.ua
NEXT_PUBLIC_API_URL=https://demonlord.pp.ua

# Database — create at https://neon.tech
DATABASE_URL=

# Email (optional) — get at https://resend.com
RESEND_API_KEY=
-e 
# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=
